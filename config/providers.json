[
  {
    "name": "mrbilit-flight",
    "enabled": true,
    "transports": ["flight"],
    "responsePath": "Flights",
    "request": {
      "method": "POST",
      "url": "https://www.mrbilit.com/api/flight/v2/search",
      "headers": {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36",
        "Accept": "application/json, text/plain, */*",
        "Content-Type": "application/json",
        "Origin": "https://www.mrbilit.com",
        "Referer": "https://www.mrbilit.com/flight/search?origin={origin}&destination={destination}&date={date}&adult={passengers}",
        "Accept-Language": "fa-IR,fa;q=0.9,en;q=0.8",
        "Cache-Control": "no-cache",
        "Pragma": "no-cache"
      },
      "body": {
        "AdultCount": "{passengers}",
        "ChildCount": 0,
        "InfantCount": 0,
        "CabinClass": "All",
        "Routes": [
          {
            "OriginCode": "{origin}",
            "DestinationCode": "{destinationAll}",
            "DepartureDate": "{date}"
          }
        ],
        "Baggage": true,
        "IncludeFlightsWithHigherCapacity": false
      },
      "timeoutMs": 20000
    }
  },
  {
    "name": "flytoday-flight",
    "enabled": true,
    "transports": ["flight"],
    "responsePath": "result",
    "request": {
      "method": "POST",
      "url": "https://www.flytoday.ir/api/gateway/V1/Flight/FareLookUp",
      "headers": {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36",
        "Accept": "application/json",
        "Content-Type": "application/json",
        "Origin": "https://www.flytoday.ir",
        "Referer": "https://www.flytoday.ir/flight/search?departure={originLower},1&arrival={destinationLower},1&departureDate={date}&adt={passengers}&chd=0&inf=0&cabin=1&isDomestic=true&isAnyWhere=false",
        "Accept-Language": "fa-IR,fa;q=0.9,en;q=0.8",
        "X-Requested-With": "XMLHttpRequest"
      },
      "body": {
        "originLocationCode": "{origin}",
        "destinationLocationCode": "{destination}",
        "departureDate": "{date}",
        "adult": "{passengers}",
        "child": 0,
        "infant": 0,
        "lookUpType": 3
      },
      "timeoutMs": 20000
    }
  },
  {
    "name": "safarmarket-flight-calendar",
    "enabled": true,
    "transports": ["flight"],
    "request": {
      "method": "GET",
      "url": "https://safarmarket.com/api/flight/v3/calendar",
      "headers": {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36",
        "Accept": "application/json, text/html, */*",
        "Accept-Language": "fa-IR,fa;q=0.9,en;q=0.8",
        "Referer": "https://safarmarket.com/flights",
        "X-Requested-With": "XMLHttpRequest",
        "Cache-Control": "no-cache"
      },
      "query": {
        "org": "{origin}",
        "orgCity": true,
        "dst": "{destination}",
        "dstCity": true,
        "dom": true
      },
      "timeoutMs": 20000
    }
  },
  {
    "name": "trip",
    "enabled": false,
    "transports": ["flight"],
    "responsePath": "items",
    "request": {
      "method": "GET",
      "url": "{TRIP_API_URL}?origin={origin}&destination={destination}&date={date}&passengers={passengers}",
      "headers": {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36",
        "Accept": "application/json",
        "Referer": "https://www.trip.ir/"
      }
    }
  }
]
